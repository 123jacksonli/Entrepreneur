# OpenRouter configuration for Zhipu models
OPENAI_API_KEY=your-openrouter-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AGENT_MODEL=z-ai/glm-4.5

# Alternative: Direct Zhipu AI
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# DEFAULT_AGENT_MODEL=glm-4

# Storage
SQLITE_PATH=data/entrepreneur.db
OUTPUTS_DIR=outputs

# Autonomous operation safeguards
MAX_IDEA_ITERATIONS=3
MAX_QA_ITERATIONS=3
# MAX_TOKENS_PER_AGENT=16000
# STOP_ON_HIGH_COST=false

# Execution Agent version control
EXEC_BRANCH_PREFIX=exec
# GITHUB_REPO=owner/repo
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat-with-repo-scope

# Web search (optional: falls back to DuckDuckGo if not set)
# SERPAPI_API_KEY=your-serpapi-key

# X (Twitter) API v2 keys (optional)
# X_API_KEY=your-x-api-key
# X_API_SECRET=your-x-api-secret
# X_ACCESS_TOKEN=your-x-access-token
# X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# RapidAPI key for Instagram / Threads / X alternatives (optional)
# RAPIDAPI_KEY=your-rapidapi-key
